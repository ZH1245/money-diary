# Application
NODE_ENV=development
HOST=0.0.0.0
PORT=3000
SERVER_URL=http://localhost:3000
VITE_APP_TITLE=Money Diary
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=
# Encrypts AI provider API keys stored in the database (required).
# Generate: openssl rand -base64 32
ENV_SECRETS=
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Optional on Vercel: extra trusted hosts for auth (e.g. myapp.com,www.myapp.com)
# APP_ALLOWED_HOSTS=

# Database (Neon Postgres)
# Direct connection — use for migrations (pnpm db:migrate) and drizzle-kit
# Production migrations: pnpm db:migrate:prod (reads .env.prod)
#
# All instants are stored as UTC (timestamptz). After migrate, confirm in SQL:
#   SHOW timezone;   -- should be UTC
# To set the Neon database default (run once in Neon SQL editor):
#   ALTER DATABASE neondb SET timezone TO 'UTC';
DATABASE_URL=postgresql://neondb_owner:YOUR_PASSWORD@ep-young-voice-ashk76uq.c-4.eu-central-1.aws.neon.tech/neondb?sslmode=require
# Optional pooled connection — better for serverless / high concurrency (from Neon dashboard)
DATABASE_URL_POOLER=

# Email sign-in codes (Resend) — optional
# When unset, email-code sign-in is disabled; email + password still works.
RESEND_API_KEY=
# Sender address. Default onboarding@resend.dev only delivers to the Resend
# account owner's own email until you verify a domain — set a verified
# from-address (e.g. login@yourdomain.com) for real users.
RESEND_FROM=

# Pusher — realtime AI progress (optional). When unset the feature is disabled with no errors.
# Create a free app at https://pusher.com/channels and copy the keys from the App Keys tab.
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=
